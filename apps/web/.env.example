# ─── Firebase (get these from Firebase Console > Project Settings) ───
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ─── Express API (your Node.js backend URL) ──────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── M-Pesa Daraja (get from Safaricom Developer Portal) ─────────────
# These go in the API server .env, NOT here (keep secret)
# MPESA_CONSUMER_KEY=...
# MPESA_CONSUMER_SECRET=...
# MPESA_SHORTCODE=...
# MPESA_PASSKEY=...
# MPESA_CALLBACK_URL=https://your-api-domain.com/api/payments/mpesa/callback
