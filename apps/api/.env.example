PORT=4000
NODE_ENV=development

# Firebase Admin SDK (download from Firebase Console > Project Settings > Service Accounts)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# OR set as JSON string:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# M-Pesa Daraja API (Vodacom Tanzania)
# Get from: https://developer.safaricom.co.ke (sandbox) or Vodacom Tanzania Biz portal
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://your-api-domain.com/api/payments/mpesa/callback

# Airtel Money (Airtel Tanzania)
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret
AIRTEL_ENVIRONMENT=sandbox
AIRTEL_CALLBACK_URL=https://your-api-domain.com/api/payments/airtel/callback

# Africa's Talking (SMS OTP)
# Sign up free at: https://africastalking.com
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=SOKOLINK

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://sokolink.co.tz
